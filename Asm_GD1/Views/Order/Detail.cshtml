@{
    ViewBag.Title = "Chi tiết món ăn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="card border-orange">
        <div class="card-body">
            <div class="row">
                <div class="col-md-5">
                    <!-- Ảnh món ăn -->
                    <img src="https://via.placeholder.com/400x350/ff9800/ffffff?text=Cơm+Gà" class="img-fluid rounded shadow" alt="Tên món ăn">
                </div>
                <div class="col-md-7">
                    <!-- Tên món ăn -->
                    <h2 class="text-orange font-weight-bold">Cơm Gà Xối Mỡ</h2>

                    <!-- Đánh giá sao -->
                    <div class="mb-2">
                        <span class="text-orange">★★★★☆</span>
                        <span class="text-muted">(15 đánh giá)</span>
                    </div>

                    <!-- Giá tiền -->
                    <h3 class="text-orange my-3">35.000đ</h3>

                    <!-- Mô tả ngắn -->
                    <p class="lead">
                        Món ăn đặc biệt với lớp da gà giòn rụm, thịt gà mềm ngọt, ăn kèm với cơm chiên và nước sốt đặc trưng.
                    </p>

                    <!-- Thành phần/Dinh dưỡng -->
                    <ul class="list-unstyled mb-4">
                        <li>✔️ Nguyên liệu tươi sạch mỗi ngày</li>
                        <li>✔️ Dinh dưỡng: ~560 kcal/phần</li>
                        <li>✔️ Phù hợp cho bữa trưa văn phòng</li>
                    </ul>

                    <form>
                        <!-- Tùy chọn thêm (Topping) -->
                        <div class="form-group">
                            <label class="font-weight-bold">Tùy chọn thêm:</label>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="themTrung">
                                <label class="form-check-label" for="themTrung">
                                    Thêm trứng ốp la (+5.000đ)
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="themCha">
                                <label class="form-check-label" for="themCha">
                                    Thêm chả lụa (+7.000đ)
                                </label>
                            </div>
                        </div>

                        <!-- Chọn số lượng -->
                        <div class="form-group">
                            <label for="quantity" class="font-weight-bold">Số lượng:</label>
                            <input type="number" id="quantity" class="form-control" value="1" min="1" style="width: 120px;">
                        </div>

                        <!-- Nút thêm vào giỏ -->
                        <button type="submit" class="btn btn-orange btn-lg mt-3">
                            Thêm vào giỏ hàng
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Tab Bình luận và Mô tả chi tiết -->
    <div class="mt-5">
        <ul class="nav nav-tabs">
            <li class="nav-item">
                <a class="nav-link active text-orange" data-toggle="tab" href="#reviews">Đánh giá & Bình luận</a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-orange" data-toggle="tab" href="#description">Mô tả chi tiết</a>
            </li>
        </ul>
        <div class="tab-content card p-3">
            <div id="reviews" class="tab-pane active">
                <p>Ngon, suất ăn lớn, giao hàng nhanh!</p>
                <small class="text-muted">- Nguyễn Văn A, 2 giờ trước</small>
                <hr>
                <p>Món ăn tuyệt vời.</p>
                <small class="text-muted">- Trần Thị B, 5 giờ trước</small>
            </div>
            <div id="description" class="tab-pane fade">
                <p>Thông tin chi tiết về nguồn gốc nguyên liệu, quy trình chế biến, giá trị dinh dưỡng...</p>
            </div>
        </div>
    </div>
</div>
