@{
    ViewBag.Title = "Quản lý thực đơn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Navigation tabs cho admin -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-orange p-0">
                <ul class="nav nav-tabs card-header-tabs" id="adminTabs">
                    <li class="nav-item">
                        <a class="nav-link active text-white" href="/Admin/Menu">
                            🍽️ Quản lý thực đơn
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Admin/Order">
                            📋 Quản lý đơn hàng
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Admin/Promotion">
                            🎁 Quản lý khuyến mãi
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Admin/User">
                            👥 Quản lý người dùng
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Admin/Report">
                            📊 Báo cáo thống kê
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Header và nút thêm món -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-orange mb-0">🍽️ Quản lý thực đơn</h2>
    <div>
        <button class="btn btn-outline-orange mr-2" data-toggle="modal" data-target="#importMenuModal">
            📥 Import Excel
        </button>
        <button class="btn btn-orange" data-toggle="modal" data-target="#addMenuModal">
            ➕ Thêm món mới
        </button>
    </div>
</div>

<!-- Bộ lọc và tìm kiếm -->
<div class="card mb-4">
    <div class="card-body">
        <form class="form-inline">
            <input type="text" class="form-control mr-2" placeholder="Tìm tên món..." style="width: 200px;">
            <select class="form-control mr-2" style="width: 120px;">
                <option>-- Danh mục --</option>
                <option>Cơm</option>
                <option>Bún/Phở</option>
                <option>Mì/Pasta</option>
                <option>Đồ uống</option>
                <option>Tráng miệng</option>
            </select>
            <select class="form-control mr-2" style="width: 120px;">
                <option>-- Trạng thái --</option>
                <option>Đang bán</option>
                <option>Hết hàng</option>
                <option>Ngừng bán</option>
            </select>
            <button type="submit" class="btn btn-orange">🔍 Lọc</button>
            <button type="button" class="btn btn-outline-orange ml-2">🔄 Làm mới</button>
        </form>
    </div>
</div>

<!-- Bảng quản lý thực đơn -->
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="bg-orange">
                    <tr>
                        <th>
                            <input type="checkbox" id="selectAll">
                        </th>
                        <th>Hình ảnh</th>
                        <th>Tên món</th>
                        <th>Giá</th>
                        <th>Danh mục</th>
                        <th>Trạng thái</th>
                        <th>Đã bán</th>
                        <th>Đánh giá</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var menuItems = new[] {
                                        new { Id = 1, Name = "Cơm Gà Xối Mỡ", Description = "Thơm ngon, giòn rụm", Price = 35000, Category = "Cơm", Status = "Đang bán", StatusClass = "success", Sold = 45, Rating = "4.5", Image = "Cơm+Gà" },
                                        new { Id = 2, Name = "Bún Bò Huế", Description = "Đậm đà, cay nhẹ", Price = 40000, Category = "Bún/Phở", Status = "Đang bán", StatusClass = "success", Sold = 32, Rating = "4.3", Image = "Bún+Bò" },
                                        new { Id = 3, Name = "Mì Ý Sốt Kem", Description = "Phong cách châu Âu", Price = 45000, Category = "Mì/Pasta", Status = "Hết hàng", StatusClass = "warning", Sold = 28, Rating = "4.7", Image = "Mì+Ý" },
                                        new { Id = 4, Name = "Phở Bò Tái", Description = "Nước dùng trong", Price = 38000, Category = "Bún/Phở", Status = "Đang bán", StatusClass = "success", Sold = 53, Rating = "4.4", Image = "Phở+Bò" },
                                        new { Id = 5, Name = "Bánh Mì Thịt Nướng", Description = "Bánh giòn, thịt thơm", Price = 25000, Category = "Bánh mì", Status = "Ngừng bán", StatusClass = "danger", Sold = 67, Rating = "4.2", Image = "Bánh+Mì" }
                                        };
                    }

                    @foreach (var item in menuItems)
                    {
                        <tr>
                            <td>
                                <input type="checkbox" name="selectedItems" value="@item.Id">
                            </td>
                            <td>
                                <img src="https://via.placeholder.com/60x40/ff9800/ffffff?text=@item.Image"
                                     class="img-thumbnail" alt="@item.Name" style="width: 60px; height: 40px;">
                            </td>
                            <td>
                                <div>
                                    <strong class="text-orange">@item.Name</strong><br>
                                    <small class="text-muted">@item.Description</small>
                                </div>
                            </td>
                            <td>
                                <strong class="text-orange">@item.Price.ToString("N0")đ</strong>
                            </td>
                            <td>
                                <span class="badge badge-info">@item.Category</span>
                            </td>
                            <td>
                                <span class="badge badge-@item.StatusClass">@item.Status</span>
                            </td>
                            <td>
                                <span class="text-orange font-weight-bold">@item.Sold</span> phần
                            </td>
                            <td>
                                <span class="text-warning">⭐ @item.Rating</span>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <button class="btn btn-sm btn-outline-orange" title="Sửa">
                                        ✏️
                                    </button>
                                    <button class="btn btn-sm btn-outline-info" title="Sao chép">
                                        📋
                                    </button>
                                    @if (item.Status == "Đang bán")
                                    {
                                        <button class="btn btn-sm btn-warning" title="Tạm ngừng">
                                            ⏸️
                                        </button>
                                    }
                                    else if (item.Status == "Hết hàng")
                                    {
                                        <button class="btn btn-sm btn-success" title="Còn hàng">
                                            ✅
                                        </button>
                                    }
                                    else if (item.Status == "Ngừng bán")
                                    {
                                        <button class="btn btn-sm btn-success" title="Bán lại">
                                            ▶️
                                        </button>
                                    }
                                    <button class="btn btn-sm btn-danger" title="Xóa">
                                        🗑️
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Thao tác hàng loạt -->
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div>
                <button class="btn btn-outline-orange" disabled id="bulkActions">
                    Thao tác hàng loạt (0 mục được chọn)
                </button>
            </div>

            <!-- Phân trang -->
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item"><a class="page-link text-orange" href="#">‹</a></li>
                    <li class="page-item active"><a class="page-link bg-orange border-orange" href="#">1</a></li>
                    <li class="page-item"><a class="page-link text-orange" href="#">2</a></li>
                    <li class="page-item"><a class="page-link text-orange" href="#">3</a></li>
                    <li class="page-item"><a class="page-link text-orange" href="#">›</a></li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<!-- Thống kê nhanh -->
<div class="row mt-4">
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <h3>156</h3>
                <p class="mb-0">Món đang bán</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-white">
            <div class="card-body text-center">
                <h3>12</h3>
                <p class="mb-0">Hết hàng</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white">
            <div class="card-body text-center">
                <h3>8</h3>
                <p class="mb-0">Ngừng bán</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-orange text-white">
            <div class="card-body text-center">
                <h3>2.1M</h3>
                <p class="mb-0">Doanh thu tháng</p>
            </div>
        </div>
    </div>
</div>

<!-- Modal thêm món mới -->
<div class="modal fade" id="addMenuModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-orange">
                <h5 class="modal-title">➕ Thêm món ăn mới</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="row">
                        <div class="col-md-8">
                            <div class="form-group">
                                <label>Tên món ăn:</label>
                                <input type="text" class="form-control" placeholder="VD: Cơm gà xối mỡ" required>
                            </div>
                            <div class="form-group">
                                <label>Mô tả:</label>
                                <textarea class="form-control" rows="3" placeholder="Mô tả chi tiết về món ăn..."></textarea>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Hình ảnh:</label>
                                <input type="file" class="form-control-file" accept="image/*">
                                <div class="mt-2">
                                    <img id="preview" class="img-thumbnail" style="width: 100px; height: 80px; display: none;">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Giá bán:</label>
                                <input type="number" class="form-control" placeholder="35000" required>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Danh mục:</label>
                                <select class="form-control" required>
                                    <option>Cơm</option>
                                    <option>Bún/Phở</option>
                                    <option>Mì/Pasta</option>
                                    <option>Đồ uống</option>
                                    <option>Tráng miệng</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Trạng thái:</label>
                                <select class="form-control">
                                    <option>Đang bán</option>
                                    <option>Hết hàng</option>
                                    <option>Ngừng bán</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-orange" data-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-orange">💾 Lưu món ăn</button>
            </div>
        </div>
    </div>
</div>

<script>
    // JavaScript để xử lý checkbox và navigation
    document.addEventListener('DOMContentLoaded', function() {
        // Xử lý select all checkbox
        const selectAllCheckbox = document.getElementById('selectAll');
        const itemCheckboxes = document.querySelectorAll('input[name="selectedItems"]');
        const bulkActionsBtn = document.getElementById('bulkActions');

        selectAllCheckbox.addEventListener('change', function() {
            itemCheckboxes.forEach(checkbox => {
                checkbox.checked = this.checked;
            });
            updateBulkActions();
        });

        itemCheckboxes.forEach(checkbox => {
            checkbox.addEventListener('change', updateBulkActions);
        });

        function updateBulkActions() {
            const checkedCount = document.querySelectorAll('input[name="selectedItems"]:checked').length;
            bulkActionsBtn.textContent = `Thao tác hàng loạt (${checkedCount} mục được chọn)`;
            bulkActionsBtn.disabled = checkedCount === 0;
        }
    });
</script>
