@{
    ViewBag.Title = "Quản lý đơn hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-orange mb-0">📋 Quản lý đơn hàng</h2>
    <div>
        <button class="btn btn-outline-orange mr-2">📊 Xuất báo cáo</button>
        <button class="btn btn-orange">🔄 Làm mới</button>
    </div>
</div>

<!-- Bộ lọc -->
<div class="card mb-4">
    <div class="card-body">
        <form class="form-inline">
            <input type="text" class="form-control mr-2" placeholder="Tìm theo mã đơn, tên khách..." style="width: 250px;">
            <select class="form-control mr-2" style="width: 150px;">
                <option>-- Trạng thái --</option>
                <option>Chờ xử lý</option>
                <option>Đang chuẩn bị</option>
                <option>Đang giao</option>
                <option>Hoàn thành</option>
                <option>Đã hủy</option>
            </select>
            <input type="date" class="form-control mr-2">
            <button type="submit" class="btn btn-orange">🔍 Lọc</button>
        </form>
    </div>
</div>

<!-- Bảng danh sách đơn hàng -->
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="bg-orange">
                    <tr>
                        <th>Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Món ăn</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var orders = new[] {
                                        new { Id = "#2025001", Customer = "Nguyễn Văn A", Date = "24/07/2025 08:30", Items = "Cơm gà, Bún bò", Total = 75000, Status = "Chờ xử lý", StatusClass = "warning" },
                                        new { Id = "#2025002", Customer = "Trần Thị B", Date = "24/07/2025 09:15", Items = "Phở bò, Chè đậu", Total = 53000, Status = "Đang chuẩn bị", StatusClass = "info" },
                                        new { Id = "#2025003", Customer = "Lê Văn C", Date = "24/07/2025 09:45", Items = "Mì Ý sốt kem", Total = 45000, Status = "Đang giao", StatusClass = "primary" },
                                        new { Id = "#2025004", Customer = "Phạm Thị D", Date = "23/07/2025 12:20", Items = "Bánh mì, Gỏi cuốn", Total = 55000, Status = "Hoàn thành", StatusClass = "success" },
                                        new { Id = "#2025005", Customer = "Hoàng Văn E", Date = "23/07/2025 11:10", Items = "Cháo sườn", Total = 32000, Status = "Đã hủy", StatusClass = "danger" }
                                        };
                    }

                    @foreach (var order in orders)
                    {
                        <tr>
                            <td>
                                <strong class="text-orange">@order.Id</strong>
                            </td>
                            <td>
                                <div>
                                    <strong>@order.Customer</strong><br>
                                    <small class="text-muted">📞 0901234567</small>
                                </div>
                            </td>
                            <td>
                                <small>@order.Date</small>
                            </td>
                            <td>
                                <small>@order.Items</small>
                            </td>
                            <td>
                                <strong class="text-orange">@order.Total.ToString("N0")đ</strong>
                            </td>
                            <td>
                                <span class="badge badge-@order.StatusClass">@order.Status</span>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <button class="btn btn-sm btn-outline-orange" title="Xem chi tiết">
                                        👁️
                                    </button>
                                    @if (order.Status == "Chờ xử lý")
                                    {
                                        <button class="btn btn-sm btn-success" title="Xác nhận">
                                            ✅
                                        </button>
                                        <button class="btn btn-sm btn-danger" title="Hủy đơn">
                                            ❌
                                        </button>
                                    }
                                    else if (order.Status == "Đang chuẩn bị")
                                    {
                                        <button class="btn btn-sm btn-primary" title="Chuyển sang giao hàng">
                                            🚚
                                        </button>
                                    }
                                    else if (order.Status == "Đang giao")
                                    {
                                        <button class="btn btn-sm btn-success" title="Hoàn thành">
                                            ✅
                                        </button>
                                    }
                                    <button class="btn btn-sm btn-secondary" title="In hóa đơn">
                                        🖨️
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Phân trang -->
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item"><a class="page-link text-orange" href="#">‹ Trước</a></li>
                <li class="page-item active"><a class="page-link bg-orange border-orange" href="#">1</a></li>
                <li class="page-item"><a class="page-link text-orange" href="#">2</a></li>
                <li class="page-item"><a class="page-link text-orange" href="#">3</a></li>
                <li class="page-item"><a class="page-link text-orange" href="#">Sau ›</a></li>
            </ul>
        </nav>
    </div>
</div>

<!-- Thống kê nhanh -->
<div class="row mt-4">
    <div class="col-md-3">
        <div class="card bg-warning text-white">
            <div class="card-body text-center">
                <h3>12</h3>
                <p class="mb-0">Chờ xử lý</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-white">
            <div class="card-body text-center">
                <h3>8</h3>
                <p class="mb-0">Đang chuẩn bị</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <h3>5</h3>
                <p class="mb-0">Đang giao</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <h3>156</h3>
                <p class="mb-0">Hoàn thành hôm nay</p>
            </div>
        </div>
    </div>
</div>
