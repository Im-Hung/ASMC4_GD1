@{
    ViewBag.Title = "Quản lý khuyến mãi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-orange mb-0">🎁 Quản lý mã khuyến mãi</h2>
    <button class="btn btn-orange" data-toggle="modal" data-target="#addPromotionModal">
        ➕ Thêm mã mới
    </button>
</div>

<!-- Bộ lọc -->
<div class="card mb-4">
    <div class="card-body">
        <form class="form-inline">
            <input type="text" class="form-control mr-2" placeholder="Tìm theo mã khuyến mãi..." style="width: 200px;">
            <select class="form-control mr-2" style="width: 120px;">
                <option>-- Trạng thái --</option>
                <option>Đang hoạt động</option>
                <option>Sắp hết hạn</option>
                <option>Đã hết hạn</option>
                <option>Đã tạm dừng</option>
            </select>
            <input type="date" class="form-control mr-2" placeholder="Từ ngày">
            <input type="date" class="form-control mr-2" placeholder="Đến ngày">
            <button type="submit" class="btn btn-orange">🔍 Lọc</button>
        </form>
    </div>
</div>

<!-- Bảng danh sách mã khuyến mãi -->
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="bg-orange">
                    <tr>
                        <th>Mã KM</th>
                        <th>Tên chương trình</th>
                        <th>Loại giảm giá</th>
                        <th>Giá trị</th>
                        <th>Điều kiện</th>
                        <th>Thời hạn</th>
                        <th>Đã dùng</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var promotions = new[] {
                                        new { Code = "WELCOME20", Name = "Chào mừng thành viên mới", Type = "Phần trăm", Value = "20%", Condition = "Đơn từ 50k", StartDate = "01/07/2025", EndDate = "31/07/2025", Used = 45, Limit = 100, Status = "Đang hoạt động", StatusClass = "success" },
                                        new { Code = "LUNCH30", Name = "Ưu đãi bữa trưa", Type = "Giảm tiền", Value = "30.000đ", Condition = "Đơn từ 100k", StartDate = "15/07/2025", EndDate = "30/07/2025", Used = 23, Limit = 50, Status = "Đang hoạt động", StatusClass = "success" },
                                        new { Code = "COMBO15", Name = "Combo tiết kiệm", Type = "Phần trăm", Value = "15%", Condition = "Mua combo", StartDate = "10/07/2025", EndDate = "25/07/2025", Used = 12, Limit = 30, Status = "Sắp hết hạn", StatusClass = "warning" },
                                        new { Code = "FREESHIP", Name = "Miễn phí giao hàng", Type = "Miễn ship", Value = "100%", Condition = "Đơn từ 80k", StartDate = "01/07/2025", EndDate = "20/07/2025", Used = 67, Limit = 200, Status = "Đã hết hạn", StatusClass = "danger" },
                                        new { Code = "VIP50", Name = "Khách VIP", Type = "Giảm tiền", Value = "50.000đ", Condition = "Thành viên VIP", StartDate = "01/07/2025", EndDate = "31/12/2025", Used = 8, Limit = 999, Status = "Tạm dừng", StatusClass = "secondary" }
                                        };
                    }

                    @foreach (var promo in promotions)
                    {
                        <tr>
                            <td>
                                <strong class="text-orange">@promo.Code</strong>
                            </td>
                            <td>@promo.Name</td>
                            <td>
                                <span class="badge badge-info">@promo.Type</span>
                            </td>
                            <td>
                                <strong class="text-success">@promo.Value</strong>
                            </td>
                            <td>
                                <small>@promo.Condition</small>
                            </td>
                            <td>
                                <small>
                                    @promo.StartDate<br>
                                    → @promo.EndDate
                                </small>
                            </td>
                            <td>
                                <span class="text-orange">@promo.Used</span>/@promo.Limit
                                <div class="progress" style="height: 5px;">
                                    @{
                                        var percentage = (double)promo.Used / promo.Limit * 100;
                                    }
                                    <div class="progress-bar bg-orange" style="width: @percentage%"></div>
                                </div>
                            </td>
                            <td>
                                <span class="badge badge-@promo.StatusClass">@promo.Status</span>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <button class="btn btn-sm btn-outline-orange" title="Sửa">
                                        ✏️
                                    </button>
                                    @if (promo.Status == "Đang hoạt động")
                                    {
                                        <button class="btn btn-sm btn-warning" title="Tạm dừng">
                                            ⏸️
                                        </button>
                                    }
                                    else if (promo.Status == "Tạm dừng")
                                    {
                                        <button class="btn btn-sm btn-success" title="Kích hoạt">
                                            ▶️
                                        </button>
                                    }
                                    <button class="btn btn-sm btn-danger" title="Xóa">
                                        🗑️
                                    </button>
                                    <button class="btn btn-sm btn-info" title="Sao chép">
                                        📋
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal thêm mã khuyến mãi mới -->
<div class="modal fade" id="addPromotionModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-orange">
                <h5 class="modal-title">➕ Thêm mã khuyến mãi mới</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Mã khuyến mãi:</label>
                                <input type="text" class="form-control" placeholder="VD: SUMMER2025" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Tên chương trình:</label>
                                <input type="text" class="form-control" placeholder="VD: Ưu đãi mùa hè" required>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Loại giảm giá:</label>
                                <select class="form-control" required>
                                    <option>Phần trăm</option>
                                    <option>Giảm tiền</option>
                                    <option>Miễn ship</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Giá trị:</label>
                                <input type="number" class="form-control" placeholder="20" required>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Điều kiện tối thiểu:</label>
                                <input type="number" class="form-control" placeholder="50000">
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Ngày bắt đầu:</label>
                                <input type="datetime-local" class="form-control" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Ngày kết thúc:</label>
                                <input type="datetime-local" class="form-control" required>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Giới hạn sử dụng:</label>
                                <input type="number" class="form-control" placeholder="100">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Trạng thái:</label>
                                <select class="form-control">
                                    <option>Đang hoạt động</option>
                                    <option>Tạm dừng</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Mô tả:</label>
                        <textarea class="form-control" rows="3" placeholder="Mô tả chi tiết về chương trình khuyến mãi..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-orange" data-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-orange">💾 Lưu</button>
            </div>
        </div>
    </div>
</div>

<!-- Thống kê khuyến mãi -->
<div class="row mt-4">
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <h3>12</h3>
                <p class="mb-0">Đang hoạt động</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-white">
            <div class="card-body text-center">
                <h3>3</h3>
                <p class="mb-0">Sắp hết hạn</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white">
            <div class="card-body text-center">
                <h3>8</h3>
                <p class="mb-0">Đã hết hạn</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-orange text-white">
            <div class="card-body text-center">
                <h3>1.2M</h3>
                <p class="mb-0">Tiết kiệm cho khách</p>
            </div>
        </div>
    </div>
</div>
