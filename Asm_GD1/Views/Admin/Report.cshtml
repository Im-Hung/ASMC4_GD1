@{
    ViewBag.Title = "Báo cáo thống kê";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Navigation tabs cho admin -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-orange p-0">
                <ul class="nav nav-tabs card-header-tabs" id="adminTabs">
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Admin/Menu">
                            🍽️ Quản lý thực đơn
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Admin/Order">
                            📋 Quản lý đơn hàng
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Admin/Promotion">
                            🎁 Quản lý khuyến mãi
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Admin/User">
                            👥 Quản lý người dùng
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active text-white" href="/Admin/Report">
                            📊 Báo cáo thống kê
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Header và nút xuất báo cáo -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-orange mb-0">📊 Báo cáo thống kê</h2>
    <div>
        <button class="btn btn-outline-orange mr-2">📥 Xuất Excel</button>
        <button class="btn btn-outline-orange mr-2">📄 Xuất PDF</button>
        <button class="btn btn-orange">🔄 Làm mới</button>
    </div>
</div>

<!-- Bộ lọc thời gian -->
<div class="card mb-4">
    <div class="card-body">
        <form class="form-inline">
            <label class="mr-2">Thời gian:</label>
            <select class="form-control mr-2" style="width: 150px;">
                <option>Hôm nay</option>
                <option>7 ngày qua</option>
                <option>Tháng này</option>
                <option>Tháng trước</option>
                <option>3 tháng qua</option>
                <option>Năm nay</option>
                <option>Tùy chỉnh</option>
            </select>
            <input type="date" class="form-control mr-2" placeholder="Từ ngày">
            <input type="date" class="form-control mr-2" placeholder="Đến ngày">
            <button type="submit" class="btn btn-orange">📊 Xem báo cáo</button>
        </form>
    </div>
</div>

<!-- Thống kê tổng quan -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <h3>1,234</h3>
                <p class="mb-0">Tổng đơn hàng</p>
                <small>↗️ +12% so với tuần trước</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <h3>45.6M</h3>
                <p class="mb-0">Doanh thu</p>
                <small>↗️ +8% so với tuần trước</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-white">
            <div class="card-body text-center">
                <h3>89</h3>
                <p class="mb-0">Món ăn đã bán</p>
                <small>↗️ +5% so với tuần trước</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-orange text-white">
            <div class="card-body text-center">
                <h3>567</h3>
                <p class="mb-0">Khách hàng mới</p>
                <small>↗️ +15% so với tuần trước</small>
            </div>
        </div>
    </div>
</div>

<!-- Biểu đồ và báo cáo chi tiết -->
<div class="row">
    <!-- Biểu đồ doanh thu -->
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-orange">
                <h5 class="mb-0">📈 Biểu đồ doanh thu 7 ngày qua</h5>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" height="100"></canvas>
                <!-- Placeholder cho biểu đồ -->
                <div class="text-center py-5 text-muted">
                    <h5>Biểu đồ doanh thu sẽ được hiển thị ở đây</h5>
                    <p>Sử dụng Chart.js để tích hợp biểu đồ thực tế</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Top món ăn bán chạy -->
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-orange">
                <h5 class="mb-0">🏆 Top món bán chạy</h5>
            </div>
            <div class="card-body">
                @{
                    var topFoods = new[] {
                                new { Name = "Cơm Gà Xối Mỡ", Sold = 245, Revenue = 8575000 },
                                new { Name = "Bún Bò Huế", Sold = 189, Revenue = 7560000 },
                                new { Name = "Phở Bò Tái", Sold = 156, Revenue = 5928000 },
                                new { Name = "Mì Ý Sốt Kem", Sold = 134, Revenue = 6030000 },
                                new { Name = "Bánh Mì Thịt Nướng", Sold = 123, Revenue = 3075000 }
                                };
                }

                @foreach (var food in topFoods.Take(5))
                {
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <strong class="text-orange">@food.Name</strong><br>
                            <small class="text-muted">@food.Sold phần - @food.Revenue.ToString("N0")đ</small>
                        </div>
                        <span class="badge badge-orange">@food.Sold</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Bảng báo cáo chi tiết -->
<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-orange">
                <h5 class="mb-0">📊 Báo cáo theo danh mục</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Danh mục</th>
                                <th>Số món</th>
                                <th>Đã bán</th>
                                <th>Doanh thu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var categories = new[] {
                                                        new { Name = "Cơm", Items = 45, Sold = 567, Revenue = 19845000 },
                                                        new { Name = "Bún/Phở", Items = 32, Sold = 423, Revenue = 16456000 },
                                                        new { Name = "Mì/Pasta", Items = 18, Sold = 234, Revenue = 9876000 },
                                                        new { Name = "Đồ uống", Items = 25, Sold = 789, Revenue = 5643000 },
                                                        new { Name = "Tráng miệng", Items = 12, Sold = 156, Revenue = 2340000 }
                                                        };
                            }

                            @foreach (var cat in categories)
                            {
                                <tr>
                                    <td><strong class="text-orange">@cat.Name</strong></td>
                                    <td>@cat.Items</td>
                                    <td>@cat.Sold</td>
                                    <td>@cat.Revenue.ToString("N0")đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-orange">
                <h5 class="mb-0">⏰ Báo cáo theo giờ</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Giờ</th>
                                <th>Số đơn</th>
                                <th>Doanh thu</th>
                                <th>Tỷ lệ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var hourlyStats = new[] {
                                                        new { Hour = "11:00-12:00", Orders = 89, Revenue = 3456000, Percent = 35 },
                                                        new { Hour = "12:00-13:00", Orders = 156, Revenue = 6234000, Percent = 62 },
                                                        new { Hour = "13:00-14:00", Orders = 134, Revenue = 5123000, Percent = 51 },
                                                        new { Hour = "17:00-18:00", Orders = 78, Revenue = 2987000, Percent = 30 },
                                                        new { Hour = "18:00-19:00", Orders = 92, Revenue = 3567000, Percent = 36 }
                                                        };
                            }

                            @foreach (var hour in hourlyStats)
                            {
                                <tr>
                                    <td><strong>@hour.Hour</strong></td>
                                    <td>@hour.Orders</td>
                                    <td>@hour.Revenue.ToString("N0")đ</td>
                                    <td>
                                        <div class="progress" style="height: 10px;">
                                            <div class="progress-bar bg-orange" style="width: @hour.Percent%"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Xu hướng và dự báo -->
<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-orange">
                <h5 class="mb-0">🔮 Phân tích xu hướng & Dự báo</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <div class="text-center mb-3">
                            <h6 class="text-orange">Giờ cao điểm</h6>
                            <h4>12:00 - 13:00</h4>
                            <small class="text-muted">62% tổng đơn hàng</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-center mb-3">
                            <h6 class="text-orange">Món được yêu thích nhất</h6>
                            <h4>Cơm Gà Xối Mỡ</h4>
                            <small class="text-muted">245 phần bán ra</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-center mb-3">
                            <h6 class="text-orange">Dự báo doanh thu tuần sau</h6>
                            <h4 class="text-success">↗️ +15%</h4>
                            <small class="text-muted">Khoảng 52M đồng</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

