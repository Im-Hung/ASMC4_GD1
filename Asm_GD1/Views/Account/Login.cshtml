@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/login.css" />
}

<div class="auth-container">
    <div class="auth-form">
        <h2>Đăng nhập</h2>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i>
                @ViewBag.Error
            </div>
        }

        <form asp-controller="Account" asp-action="Login" method="post">
            <div class="form-group">
                <label>Email hoặc tên đăng nhập</label>
                <input type="text" name="username" class="form-control" required>
            </div>

            <div class="form-group">
                <label>Mật khẩu</label>
                <input type="password" name="password" class="form-control" required>
            </div>

            <div class="form-check">
                <input type="checkbox" name="rememberMe" class="form-check-input">
                <label class="form-check-label">Ghi nhớ đăng nhập</label>
            </div>

            <button type="submit" class="btn-primary">Đăng nhập</button>
        </form>

        <div class="auth-links">
            <a href="#" class="forgot-password">Quên mật khẩu?</a>
            <p>Chưa có tài khoản? <a asp-action="Register">Đăng ký ngay</a></p>
        </div>

        <div class="social-login">
            <button class="btn-google">
                <img src="~/Images/google-icon.png" alt="Google">
                Đăng nhập với Google
            </button>
        </div>

        <!-- Demo Info -->
        <div class="demo-info">
            <p><strong>Tài khoản demo:</strong></p>
            <ul>
                <li>Khách hàng: <code>user</code> / <code>user</code></li>
                <li>Admin User: <code>admin</code> / <code>admin</code></li>
                <li>Admin Food: <code>admin1</code> / <code>admin1</code></li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hiển thị thông báo thành công và chuyển trang
        @if (ViewBag.SuccessMessage != null)
        {
                <text>
                document.addEventListener('DOMContentLoaded', function() {
                    // Hiển thị notification success
                    showNotification('@Html.Raw(ViewBag.SuccessMessage)', 'success');

                    // Chuyển trang sau 2 giây
                    setTimeout(function() {
                        window.location.href = '@ViewBag.RedirectUrl';
                    }, 2000);
                });
                </text>
        }
    </script>
}
